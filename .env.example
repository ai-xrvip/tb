# 4KHD Gallery Search Bot Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your-bot-token-here

# Search settings
MAX_SEARCH_RESULTS=10
MAX_PAGES_PER_POST=5
MAX_IMAGES_PER_POST=30

# Cache TTL in seconds
CACHE_TTL=300
CACHE_MAX_ENTRIES=500

# Rate limiting
MAX_SEARCHES_PER_MINUTE=10

# Admin user IDs (comma-separated)
ADMIN_IDS=123456789

# Webhook (leave empty for polling mode)
WEBHOOK_URL=
WEBHOOK_PORT=8000

# SSL verification
SSL_VERIFY=true

# E-Hentai cookies (for cosplay gallery search)
EH_MEMBER_ID=
EH_PASS_HASH=
EH_SK=
EH_EVENT=
EH_IQ=
