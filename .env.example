# ── LLM 提供商选择 ──
LLM_PROVIDER=deepseek

# ── DeepSeek ──
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI（可选，用于语音/生图等高级功能） ──
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# ── 流式输出 ──
ENABLE_STREAMING=true

# ── Bot Token（多角色，每个角色一个 Token） ──
XIAOLU_BOT_TOKEN=123456:ABC-DEF1234ghijkl
# 其他角色可选：
# YUKI_BOT_TOKEN=
# HANA_BOT_TOKEN=

# ── 管理员 ──
ADMIN_IDS=你的Telegram用户ID

# ── 数据库 ──
DB_PATH=bot.db

# ── 对话设置 ──
MAX_HISTORY_ROUNDS=50
FREE_TRIAL_COUNT=20

# ── 频道公告 ──
# ANNOUNCEMENT_CHANNEL=@your_channel  # 新角色激活时在此频道发公告

# ── Webhook（生产部署用） ──
# WEBHOOK_URL=https://your-domain.com

# ── 支付模式 ──
PAYMENT_MODE=test

# ── 支付（预留） ──
DONATION_API_TOKEN=

# ── 保活（Railway 防休眠，默认每4分钟自ping /health） ──
# ENABLE_KEEPALIVE=true
# KEEPALIVE_INTERVAL=240

# ── 速率限制 ──
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=15
RATE_LIMIT_WINDOW=60

# ── 语音转文字（faster-whisper 本地模型，免费） ──
ENABLE_STT=false
WHISPER_MODEL=tiny
WHISPER_LANGUAGE=zh


# ── Speech-to-Text (STT) 语音转文字 ──
# 提供商: groq (免费) / openai (付费)
STT_PROVIDER=groq
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3
# Cloudflare STT (免费, 可选)
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# ── TTS 语音回复 ──
# ?? TTS ???? ??
TTS_ENABLED=true
TTS_PROVIDER=azure                                 # azure (??, 50???/???) / edge (????)
TTS_TRIGGER_RATE=0.15
TTS_MAX_CHARS=300
AZURE_SPEECH_KEY=                                  # Azure ???? Key
AZURE_SPEECH_REGION=eastasia                       # Azure ??
TTS_VOICE=zh-CN-XiaoxiaoNeural                     # Edge ????

# ── 插件 ──
# ENABLED_PLUGINS=plugin1,plugin2

# ── 群聊（默认开启） ──
ENABLE_GROUP_CHAT=true

# ── 语言 ──
DEFAULT_LANG=zh

