# ============================================================
#  API 密钥 & 密码 · 统一配置模板
#  复制为 .env 并填入真实值即可运行
# ============================================================

# ── LLM 提供商（选一个） ──
LLM_PROVIDER=deepseek

# ── DeepSeek API ──
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI API（可选：生图/高级功能用） ──
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# ── Bot Token（30个角色，需要几个填几个） ──
# 格式：角色ID大写_BOT_TOKEN
XIAOLU_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
