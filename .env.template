# ── 管理员 ──
ADMIN_IDS=你的Telegram用户ID

# ── 支付 ──
PAYMENT_MODE=test
# 生产模式时填以下三项
# EPAY_PID=你的易支付商户ID
# EPAY_KEY=你的易支付密钥
# EPAY_URL=https://你的易支付域名/submit.php
# EPAY_NOTIFY_URL=https://你的Bot域名/payment/callback

# ── 语音转文字 ──
ENABLE_STT=false
WHISPER_MODEL=tiny
WHISPER_LANGUAGE=zh

# ── 功能开关 ──
ENABLE_STREAMING=true
ENABLE_GROUP_CHAT=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=15
RATE_LIMIT_WINDOW=60

# ── 对话 ──
MAX_HISTORY_ROUNDS=50
FREE_TRIAL_COUNT=20

# ── 数据库 ──
DB_PATH=bot.db

# ── Webhook（Railway/服务器部署时填） ──
# WEBHOOK_URL=https://你的域名.com

# ── 插件（逗号分隔） ──
# ENABLED_PLUGINS=

# ── 语言 ──
DEFAULT_LANG=zh
